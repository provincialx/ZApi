# FreeQwenApi — пользовательские настройки (перезаписывают дефолты из src/config.js)
# Закомментированные строки показывают стандартные значения — раскомментируйте для изменения

# ═══════════════════════════════════════════════════════
# Сервер
# Порт HTTP API (по умолчанию 3264)
# PORT=3264

# Хост прослушивания (0.0.0.0 — доступен с других машин)
# HOST=0.0.0.0

# Модель по умолчанию, если клиент не указал модель в запросе
# DEFAULT_MODEL=qwen-max-latest

# ═══════════════════════════════════════════════════════
# Таймауты (миллисекунды)
# Максимальное время загрузки страницы браузером
# PAGE_TIMEOUT=120000

# Время ожидания авторизации пользователя в браузере
# AUTH_TIMEOUT=120000

# Таймаут навигации между страницами Qwen Chat
# NAVIGATION_TIMEOUT=60000

# Базовая задержка перед повторным запросом (2 сек)
# RETRY_DELAY=2000

# Пауза между SSE чанками при стриминге ответа (мс) — 20 = ~50 чанков/сек
# STREAMING_CHUNK_DELAY=20

# ═══════════════════════════════════════════════════════
# Таймауты ответов модели (минуты и миллисекунды)
# Время ожидания полного ответа от Qwen Chat.
# Сессия 30 — обёртка withRequestTimeout ломает долгоиграющие запросы.
REQUEST_TIMEOUT_MINUTES=2

# Максимальное время работы Puppeteer протокола (CDP).
# Синхронизирован с REQUEST_TIMEOUT + буфер безопасности = 8 минут.
# Сессия 41 — защищает пул страниц от зависания после таймаута запроса.
# PROTOCOL_TIMEOUT=480000

# ═══════════════════════════════════════════════════════
# Пул страниц браузера (Page Pool)
# Количество страниц в "горячем" пуле для быстрой выдачи — мягкий лимит подсказки.
# PAGE_POOL_SIZE=3

# Жёсткое ограничение на одновременно выданные страницы из пула.
# Сессия 31 — защищает от переполнения при параллельных запросах.
# MAX_ACTIVE_PAGES=5

# Время простоя страницы перед закрытием сборщиком мусора (5 минут).
# Сессия 31 — предотвращает накопление памяти Chromium в фоне.
# PAGE_IDLE_TTL_MS=300000

# Интервал запуска фоновой сборки мусора страниц (60 секунд).
# Сессия 31 — авто-удаление неактивных вкладок.
# PAGE_GC_INTERVAL_MS=60000

# ═══════════════════════════════════════════════════════
# Лимиты агента и истории
# Порог автоматического сброса контекста Qwen после N вызовов инструментов.
# После этого срабатывает Force Folding — голова + хвост + статистика.
# Сессия 10, 22 — предотвращает генерацию простого текста вместо JSON tool_calls.
TOOL_CALL_RESET_THRESHOLD=50

# Максимальный размер загружаемого файла (байт) — 10 МБ
# MAX_FILE_SIZE=10485760

# Максимальная длина локально сохраняемой истории сообщений
# MAX_HISTORY_LENGTH=100

# Количество попыток повторного запроса при временных ошибках Qwen API
# MAX_RETRY_COUNT=3

# ═══════════════════════════════════════════════════════
# Сессии и контекст
# Разрешить восстановление чата по IP+UserAgent без conversation_hint.
# Полезно когда клиент не передаёт явный conversation_id в каждом запросе.
ALLOW_UNSCOPED_SESSION_CHAT_RESTORE=true

# ═══════════════════════════════════════════════════════
# Пути к директориям (относительно корня проекта)
# Папка для сохранения токенов и cookie браузерных сессий
# SESSION_DIR=session

# Папка для загруженных файлов пользователя через API (OSS upload fallbacks).
# UPLOADS_DIR=uploads

# Папка для логов (Winston log files — info.log, warn.log, error.log)
# LOGS_DIR=logs

# ═══════════════════════════════════════════════════════
# Браузер
# Размер окна Chromium в пикселях. Используется при запуске и авторизации.
# VIEWPORT_WIDTH=1920
# VIEWPORT_HEIGHT=1080

# ═══════════════════════════════════════════════════════
# Логирование (Winston)
# Уровень логирования: info, warn, error, debug
# LOG_LEVEL=info

# Максимальный размер одного файла лога (5 МБ = 5242880 байт). По достижению — ротация.
# LOG_MAX_SIZE=5242880

# Количество файлов логов для каждого уровня. Старшие — автоматически удаляются.
# LOG_MAX_FILES=5
