#Captcha simulation (uncomment to enable)
#SIMULATE_CAPTCHA=true

# FreeQwenApi — user settings (override defaults from src/config.js)
# Commented lines show default values — uncomment to change

# ═══════════════════════════════════════════════════════
# Server
# HTTP API port (default 3264)
# PORT=3264

# Listen host (0.0.0.0 — accessible from other machines)
# HOST=0.0.0.0

# Default model when client does not specify a model in request
# DEFAULT_MODEL=qwen-max-latest

# ═══════════════════════════════════════════════════════
# Timeouts (milliseconds)
# Maximum page load time for browser
# PAGE_TIMEOUT=120000

# User authentication wait time in browser
# AUTH_TIMEOUT=120000

# Navigation timeout between Qwen Chat pages
# NAVIGATION_TIMEOUT=60000

# Base delay before retry request (2 sec)
# RETRY_DELAY=2000

# Pause between SSE chunks during response streaming (ms) — 20 = ~50 chunks/sec
# STREAMING_CHUNK_DELAY=20

# ═══════════════════════════════════════════════════════
# Model response timeouts (minutes and milliseconds)
# Wait time for full response from Qwen Chat.
# Session 30 — withRequestTimeout wrapper breaks long-running requests.
#REQUEST_TIMEOUT_MINUTES=5

# Maximum Puppeteer protocol (CDP) runtime.
# Synced with REQUEST_TIMEOUT + safety buffer = 8 minutes.
# Session 41 — protects page pool from hanging after request timeout.
# PROTOCOL_TIMEOUT=480000

# ═══════════════════════════════════════════════════════
# Browser Page Pool
# Number of pages in "hot" pool for fast allocation — soft limit hint.
# PAGE_POOL_SIZE=3

# Hard limit on simultaneously allocated pages from pool.
# Session 31 — prevents overflow during parallel requests.
# MAX_ACTIVE_PAGES=5

# Page idle time before garbage collector closes it (5 minutes).
# Session 31 — prevents Chromium memory accumulation in background.
# PAGE_IDLE_TTL_MS=300000

# Background page garbage collection interval (60 seconds).
# Session 31 — auto-removal of inactive tabs.
# PAGE_GC_INTERVAL_MS=60000

# ═══════════════════════════════════════════════════════
# Agent and history limits
# Threshold for automatic Qwen context reset after N tool calls.
# After this, Force Folding triggers — head + tail + statistics.
# Session 10, 22 — prevents plain text generation instead of JSON tool_calls.
TOOL_CALL_RESET_THRESHOLD=22

# Maximum uploadable file size (bytes) — 10 MB
# MAX_FILE_SIZE=10485760

# Maximum length of locally saved message history
# MAX_HISTORY_LENGTH=100

# Number of retry attempts on transient Qwen API errors
# MAX_RETRY_COUNT=3

# ═══════════════════════════════════════════════════════
# Sessions and context
# Allow chat restore by IP+UserAgent without conversation_hint.
# Useful when client does not pass explicit conversation_id in every request.
ALLOW_UNSCOPED_SESSION_CHAT_RESTORE=true

# ═══════════════════════════════════════════════════════
# Directory paths (relative to project root)
# Folder for saving tokens and browser session cookies
# SESSION_DIR=session

# Folder for user-uploaded files via API (OSS upload fallbacks).
# UPLOADS_DIR=uploads

# Folder for logs (Winston log files — info.log, warn.log, error.log)
# LOGS_DIR=logs

# ═══════════════════════════════════════════════════════
# Browser
# Chromium window size in pixels. Used at startup and authentication.
# VIEWPORT_WIDTH=1920
# VIEWPORT_HEIGHT=1080

# ═══════════════════════════════════════════════════════
# Logging (Winston)
# Log level: info, warn, error, debug
# LOG_LEVEL=info

# Maximum single log file size (5 MB = 5242880 bytes). Rotation on reach.
# LOG_MAX_SIZE=5242880

# Number of log files per level. Older ones are automatically deleted.
# LOG_MAX_FILES=5
