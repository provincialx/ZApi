{
  "name": "free-qwen-api",
  "version": "1.0.0",
  "description": "Мульти-провайдерный OpenAI-compatible API прокси (Qwen, DeepSeek)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "node --test --test-force-exit tests/unit/*.test.js",
    "auth": "node scripts/auth.js",
    "models:sync": "node scripts/sync_models.js",
    "smoke": "node scripts/smoke_test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" index.js scripts/**/*.js tests/**/*.js",
    "format:check": "prettier --check \"src/**/*.js\" index.js scripts/**/*.js tests/**/*.js",
    "test:cov": "c8 node --test --test-force-exit tests/unit/*.test.js"
  },
  "dependencies": {
    "ali-oss": "^6.18.0",
    "axios": "^1.9.0",
    "body-parser": "^1.20.2",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "form-data": "^4.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "puppeteer": "^24.31.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
